SOLANA_NETWORK=devnet                          # devnet or mainnet-beta

# RPC — Alchemy Solana Devnet
RPC_ENDPOINT=https://solana-devnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Geyser — Alchemy Yellowstone gRPC (PAYG or Enterprise plan required)
# Format is HOST:PORT only — no https://, no trailing slash
# Auth token = your Alchemy API key (sent as X-Token header by the client)
GEYSER_ENDPOINT=solana-devnet.g.alchemy.com:443
GEYSER_TOKEN=YOUR_ALCHEMY_KEY                  # same as your Alchemy API key

# Jito — testnet global endpoint (Jito does NOT support devnet)
JITO_BLOCK_ENGINE_URL=https://testnet.block-engine.jito.wtf

PAYER_PRIVATE_KEY=your-base58-private-key      # base58 encoded Solana keypair
ANTHROPIC_API_KEY=                             # optional if using Gemini
GEMINI_API_KEY=                                # optional if using Anthropic
AI_PROVIDER=gemini                             # anthropic | gemini
SERVER_PORT=3001
AGENT_MAX_RETRIES=3
LOG_LEVEL=info                                 # debug | info | warn | error
INJECT_FAULT=none                              # blockhash | low_fee | leader_skip | none
DB_PATH=./logs/dispatcher.db

